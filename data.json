// ═══════════════════════════════════════════════════════
//  INIT: load from GitHub, then render page
// ═══════════════════════════════════════════════════════
async function init() {
  // First load: try fetching with whatever token we have (may be from localStorage)
  if (ghReady()) {
    const remote = await ghLoadData();
    if (remote) {
      D = mergeDefaults(remote, DEFAULT_DATA);
      lsSave('siteData', D);
      // Store plain gistId immediately if available
      if (D.gistId && !localStorage.getItem('gh_gist_id')) {
        localStorage.setItem('gh_gist_id', D.gistId);
        sessionStorage.setItem('gh_gist_id_s', D.gistId);
      }
      // If loaded data has an encrypted token, decrypt it using the session password
      if (D.encryptedToken && !sessionStorage.getItem('gh_token_s')) {
        const pp = sessionStorage.getItem('plain_pass_temp') || HARDCODED_PASS;
        if (pp) {
          const tok = await decryptToken(D.encryptedToken, pp);
          if (tok) {
            let gid2 = '';
            if (D.encryptedGistId) { gid2 = await decryptToken(D.encryptedGistId, pp) || ''; }
            else if (D.gistId) { gid2 = D.gistId; }
            storeToken(tok, gid2);
          }
        }
      }
    }
  } else {
    // No token yet — try fetching data.json publicly (works on public repos)
    const publicData = await ghLoadDataPublic();
    if (publicData) {
      D = mergeDefaults(publicData, DEFAULT_DATA);
      lsSave('siteData', D);
      // If it has an encrypted token, decrypt it with the session password
      if (D.encryptedToken) {
        const pp = sessionStorage.getItem('plain_pass_temp') || HARDCODED_PASS;
        if (pp) {
          const tok = await decryptToken(D.encryptedToken, pp);
          if (tok) {
            let gid2 = '';
            if (D.encryptedGistId) { gid2 = await decryptToken(D.encryptedGistId, pp) || ''; }
            else if (D.gistId) { gid2 = D.gistId; }
            storeToken(tok, gid2);
            // Persist to localStorage so it survives refreshes
            localStorage.setItem('gh_token', tok);
            setSyncStatus('ok', 'Synced');
          }
        }
      } else {
      }
    } else {
      setSyncStatus('ok', '');
    }
  }
  applyTexts();
  renderTimeline();
  renderBucket();
  renderNotes();
  renderGallery();
  const annDate = D.anniversaryDate || '2023-06-14';
  document.getElementById('anniversaryDateInput').value = annDate;
  ANNIVERSARY = new Date(annDate + 'T00:00:00');
  updateCounter();
}

// ═══════════════════════════════════════════════════════
//  COUNTER
// ═══════════════════════════════════════════════════════
let ANNIVERSARY = new Date((D.anniversaryDate || '2023-06-14') + 'T00:00:00');
function updateCounter() {
  const diff = Date.now() - ANNIVERSARY.getTime();
  if (diff < 0) return;
  const h = Math.floor(diff / 3600000), d = Math.floor(h / 24);
  document.getElementById('cnt-years').textContent  = Math.floor(d / 365.25);
  document.getElementById('cnt-months').textContent = Math.floor((d % 365.25) / 30.44);
  document.getElementById('cnt-days').textContent   = Math.floor(d % 30.44);
  document.getElementById('cnt-hours').textContent  = h % 24;
}
setInterval(updateCounter, 60000);

document.getElementById('anniversaryDateInput').addEventListener('change', async function() {
  const d = new Date(this.value + 'T00:00:00');
  if (isNaN(d)) return;
  ANNIVERSARY = d; D.anniversaryDate = this.value;
  updateCounter();
  await ghSaveData(D);
});

