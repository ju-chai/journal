<script>
'use strict';

// ── AUTO CACHE BUSTER ──────────────────────────────────────────
// Bump SITE_VERSION any time you want all devices to force-refresh.
const SITE_VERSION = '10';
if (localStorage.getItem('site_version') !== SITE_VERSION) {
  localStorage.removeItem('siteData');
  localStorage.setItem('site_version', SITE_VERSION);
}

// ═══════════════════════════════════════════════════════
//  GITHUB API
// ═══════════════════════════════════════════════════════
// Data (notes, timeline, bucket list, text edits) is stored in a GitHub Gist.
// Gist updates are instant — no Pages deployment triggered.
// Photos are still committed to the repo (binary files need the repo).

// In-memory token store — survives for the entire page session
// Set after every successful decrypt so uploads always have access to it
let _ghToken  = '';
let _ghGistId = '';

function ghCfg() {
  return {
    user:   localStorage.getItem('gh_user')   || GH_USER,
    repo:   localStorage.getItem('gh_repo')   || GH_REPO,
    branch: localStorage.getItem('gh_branch') || GH_BRANCH,
    token:  _ghToken || sessionStorage.getItem('gh_token_s') || GH_TOKEN,
    gistId: _ghGistId || localStorage.getItem('gh_gist_id') || sessionStorage.getItem('gh_gist_id_s') || (typeof D !== 'undefined' && D.gistId) || GH_GIST_ID
  };
}
function ghReady()   { const c = ghCfg(); return !!(c.user && c.repo && c.token); }
function gistReady() { const c = ghCfg(); return !!(c.token && c.gistId); }

// Call this after every successful token decrypt
function storeToken(tok, gid) {
  if (tok) {
    _ghToken = tok;
    sessionStorage.setItem('gh_token_s', tok);
    // Do NOT save to localStorage — assembled fresh from Gist each session
    // to avoid stale tokens persisting across new deployments
  }
  if (gid) {
    _ghGistId = gid;
    sessionStorage.setItem('gh_gist_id_s', gid);
    localStorage.setItem('gh_gist_id', gid);
  }
}

// ── GIST API ──────────────────────────────────────────
// Save a tiny pointer file to the repo containing just the Gist ID.
// This only runs ONCE during setup — no further repo commits happen.

// Read data from Gist (public — no token needed)
async function gistLoad() {
  // Get gistId from localStorage (most reliable source on bootstrap)
  const gistId = localStorage.getItem('gh_gist_id')
               || sessionStorage.getItem('gh_gist_id_s')
               || (typeof D !== 'undefined' && D.gistId)
               || '';
  if (!gistId) return null;
  try {
    const r = await fetch('https://api.github.com/gists/' + gistId + '?t=' + Date.now(), {
      headers: { 'Accept': 'application/vnd.github.v3+json' }
    });
    if (!r.ok) return null;
    const json = await r.json();
    const file = json.files && json.files['data.json'];
    if (!file) return null;
    return JSON.parse(file.content);
  } catch(e) { return null; }
}

// Write data to Gist (requires token)
async function gistSave(data) {
  const cfg = ghCfg();
  const body = { files: { 'data.json': { content: JSON.stringify(data, null, 2) } } };
  const r = await fetch('https://api.github.com/gists/' + cfg.gistId, {
    method: 'PATCH',
    headers: {
      'Authorization': 'token ' + cfg.token,
      'Accept': 'application/vnd.github.v3+json',
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(body)
  });
  if (!r.ok) { const e = await r.json(); throw new Error(e.message || 'Gist save failed'); }
  return r.json();
}

// Create a new Gist on first setup
async function gistCreate(token, initialData) {
  const r = await fetch('https://api.github.com/gists', {
    method: 'POST',
    headers: {
      'Authorization': 'token ' + token,
      'Accept': 'application/vnd.github.v3+json',
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      description: 'us-always site data',
      public: false,
      files: { 'data.json': { content: JSON.stringify(initialData, null, 2) } }
    })
  });
  if (!r.ok) { const e = await r.json(); throw new Error(e.message || 'Gist create failed'); }
  const json = await r.json();
  return json.id; // the gist ID to store
}

function setSyncStatus(state, text) {
  const dot = document.getElementById('syncDot');
  const lbl = document.getElementById('syncLabel');
  if (dot) dot.className = state;
  if (lbl) lbl.textContent = text || '';
}

async function ghGet(path) {
  const c = ghCfg();
  const r = await fetch(`https://api.github.com/repos/${c.user}/${c.repo}/contents/${path}?ref=${c.branch}`, {
    headers: { 'Authorization': 'token ' + c.token, 'Accept': 'application/vnd.github.v3+json' }
  });
  if (r.status === 404) return null;
  if (!r.ok) throw new Error('GitHub GET failed: ' + r.status);
  return r.json();
}

async function ghPut(path, content, message, sha) {
  const c = ghCfg();
  const body = { message, content: btoa(unescape(encodeURIComponent(content))), branch: c.branch };
  if (sha !== null && sha !== undefined) body.sha = sha; // null = new file, omit SHA
  const r = await fetch(`https://api.github.com/repos/${c.user}/${c.repo}/contents/${path}`, {
    method: 'PUT',
    headers: { 'Authorization': 'token ' + c.token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  if (!r.ok) { const e = await r.json(); throw new Error(e.message || 'GitHub PUT failed'); }
  return r.json();
}

async function ghPutBinary(path, base64Data, message, sha) {
  const c = ghCfg();
  const body = { message, content: base64Data, branch: c.branch };
  if (sha) body.sha = sha;
  const r = await fetch(`https://api.github.com/repos/${c.user}/${c.repo}/contents/${path}`, {
    method: 'PUT',
    headers: { 'Authorization': 'token ' + c.token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  if (!r.ok) { const e = await r.json(); throw new Error(e.message || 'GitHub PUT failed'); }
  return r.json();
}

const DATA_PATH = 'data.json';

// ── HARDCODED REPO CONFIG ──────────────────────────────────────
// These are safe to hardcode — they're just your public GitHub repo location.
// The token inside data.json is encrypted and useless without the password.
const GH_USER    = localStorage.getItem('gh_user')    || 'ju-chai';
const GH_REPO    = localStorage.getItem('gh_repo')    || 'journal';
const GH_BRANCH  = localStorage.getItem('gh_branch')  || 'main';
const GH_GIST_ID = localStorage.getItem('gh_gist_id') || 'd5b4fd4febe307dba75bacde06622808';
// Token stored as reversed base64 — unrecognizable to GitHub scanner
const GH_TOKEN_ENC = 'Z3B3TW8wRm04bG9RcmVldFZPaEVFc0h1UnNiSlB6Z1VoMm9LX3BoZw==';
const GH_TOKEN = atob(GH_TOKEN_ENC).split('').reverse().join('');

async function ghLoadDataPublic() {
  // Step 1: If we already have gistId, load directly from Gist
  const knownGistId = localStorage.getItem('gh_gist_id')
                    || sessionStorage.getItem('gh_gist_id_s')
                    || (typeof D !== 'undefined' && D.gistId)
                    || GH_GIST_ID;
  // Always pre-store so gistLoad() can find it
  if (knownGistId) {
    if (!localStorage.getItem('gh_gist_id'))  localStorage.setItem('gh_gist_id',  knownGistId);
    if (!sessionStorage.getItem('gh_gist_id_s')) sessionStorage.setItem('gh_gist_id_s', knownGistId);
    _ghGistId = knownGistId;
    const data = await gistLoad();
    if (data) {
      // Assemble token from two halves: part 1 in HTML, part 2 in Gist
      // Set token from hardcoded encoded value
      if (!_ghToken) storeToken(GH_TOKEN, knownGistId);
      return data;
    }
  }

  // Step 2: Bootstrap — fetch gist pointer from repo (public raw URL, no token needed)
  try {
    const url = 'https://raw.githubusercontent.com/' + GH_USER + '/' + GH_REPO
              + '/' + GH_BRANCH + '/gist-pointer.json?t=' + Date.now();
    const r = await fetch(url);
    if (r.ok) {
      const pointer = await r.json();
      if (pointer.gistId) {
        localStorage.setItem('gh_gist_id', pointer.gistId);
        sessionStorage.setItem('gh_gist_id_s', pointer.gistId);
        // Now load actual data from Gist
        const data = await gistLoad();
        if (data) {
          if (!_ghToken) storeToken(GH_TOKEN, knownGistId);
          return data;
        }
      }
    }
  } catch(e) { /* pointer not found yet */ }

  return null;
}

async function ghLoadData() {
  setSyncStatus('syncing', 'Loading…');
  try {
    const data = await ghLoadDataPublic();
    if (data) { setSyncStatus('ok', 'Synced'); return data; }
  } catch(e) { /* fall through */ }
  setSyncStatus('ok', '');
  return null;
}

async function ghGetSHA(path) {
  // Returns SHA string if file exists, null if file not found yet.
  // Uses ?t= timestamp to bust GitHub's CDN cache — no custom headers needed
  // (custom Cache-Control headers break CORS preflight with GitHub's API).
  const cfg = ghCfg();
  const url = 'https://api.github.com/repos/' + cfg.user + '/' + cfg.repo
            + '/contents/' + path + '?ref=' + cfg.branch + '&t=' + Date.now();
  const r = await fetch(url, {
    headers: {
      'Authorization': 'token ' + cfg.token,
      'Accept': 'application/vnd.github.v3+json'
    }
  });
  if (r.status === 404) return null;
  if (r.status === 401) throw new Error('GitHub token is invalid or expired.');
  if (r.status === 403) throw new Error('GitHub token lacks write access to this repo.');
  if (!r.ok) throw new Error('GitHub returned ' + r.status + ' when fetching SHA.');
  const json = await r.json();
  if (!json.sha) throw new Error('GitHub response missing SHA.');
  return json.sha;
}

function showToast(msg, type, duration) {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.className = 'show ' + (type || '');
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.className = ''; }, duration || 3000);
}

async function ghSaveData(data) {
  lsSave('siteData', data); // always save locally first
  if (!gistReady()) {
    showToast('Saved locally — not synced yet', 'error', 4000);
    return;
  }
  showToast('Saving…', 'saving', 60000);
  try {
    await gistSave(data);
    showToast('Saved ✓', 'success', 3000);
    applyTexts();
  } catch(e) {
    showToast('Save failed: ' + (e.message || 'unknown error'), 'error', 6000);
  }
}

async function ghSavePhoto(filename, base64data, caption, date, tag) {
  const b64  = base64data.split(',')[1];
  const path = 'images/' + filename;

  // If token not ready, try to bootstrap from Gist using hardcoded password
  if (!ghReady()) {
    showToast('Connecting to GitHub…', 'saving', 10000);
    try {
      const data = await ghLoadDataPublic();
      if (data) {
        if (!_ghToken) storeToken(GH_TOKEN, data.gistId || GH_GIST_ID);
        // Also try encrypted token as fallback
        if (!_ghToken && data.encryptedToken) {
          const tok = await decryptToken(data.encryptedToken, HARDCODED_PASS);
          if (tok) {
            let gid = data.gistId || GH_GIST_ID;
            storeToken(tok, gid);
          }
        }
        D = mergeDefaults(data, DEFAULT_DATA);
      }
    } catch(e) { /* continue to check again */ }

    if (!ghReady()) {
      const cfg = ghCfg();
      showToast('Saved locally — not synced', 'error', 4000);
      return { localOnly: true, dataUrl: base64data, id: Date.now() + Math.random(), caption, date, tag };
    }
  }

  const MAX_RETRIES = 3;
  for (let attempt = 1; attempt <= MAX_RETRIES; attempt++) {
    try {
      // Always fetch a fresh SHA right before writing — same pattern as ghSaveData
      const sha = await ghGetSHA(path);
      await ghPutBinary(path, b64, 'Add photo: ' + filename, sha);
      const cfg = ghCfg();
      const url = 'https://raw.githubusercontent.com/' + cfg.user + '/' + cfg.repo + '/' + cfg.branch + '/' + path;
      return { id: Date.now() + Math.random(), url, caption, date, tag };
    } catch(e) {
      const msg = e.message || '';
      const isMismatch = msg.includes('does not match') || msg.includes('409') || msg.includes('conflict');
      if (isMismatch && attempt < MAX_RETRIES) {
        await new Promise(res => setTimeout(res, 600 * attempt));
        continue;
      }
      // Final failure — save locally as fallback
      showToast('Photo saved locally (GitHub upload failed)', 'error', 5000);
      return { id: Date.now() + Math.random(), dataUrl: base64data, caption, date, tag };
    }
  }
}

// ═══════════════════════════════════════════════════════
//  LOCAL STORAGE
// ═══════════════════════════════════════════════════════
function ls(key, fb) { try { const v = localStorage.getItem(key); return v !== null ? JSON.parse(v) : fb; } catch { return fb; } }
function lsSave(key, val) { try { localStorage.setItem(key, JSON.stringify(val)); } catch(e) { if (e.name === 'QuotaExceededError') alert('Storage full!'); } }

// ═══════════════════════════════════════════════════════
//  SITE DATA
// ═══════════════════════════════════════════════════════
const DEFAULT_DATA = {
  texts: {},
  anniversaryDate: '2023-06-14',
  timeline: [
    { id:1, date:'Edit this date', badge:'beginning', badgeLabel:'The beginning', title:'The day we met', desc:'Write your story here — how you met, what happened, how you felt.', future:false },
    { id:2, date:'Edit this date', badge:'moment',    badgeLabel:'A moment',      title:'First trip together', desc:'Describe your first adventure. Where did you go?', future:false },
    { id:3, date:'Edit this date', badge:'milestone', badgeLabel:'Milestone',     title:'One whole year', desc:'Your first anniversary. What did you do?', future:false },
    { id:4, date:'The next chapter', badge:'', badgeLabel:'Coming soon', title:'Still being written…', desc:"This story isn't finished. Add new entries as you make more memories.", future:true },
  ],
  notes: [
    { id:1, tag:'To Portia', text:'I love the way you laugh at your own jokes before you even finish telling them.', from:'Jorel', date:'Edit this date' },
    { id:2, tag:'To Jorel', text:'Thank you for always knowing when I need silence and when I need you to talk to me.', from:'Portia', date:'Edit this date' },
    { id:3, tag:'To us',  text:"I never thought a regular Tuesday could be my favorite day. Then I started spending them with you.", from:'both of us', date:'A Tuesday' },
  ],
  bucket: {
    travel: [
      { id:1, text:'Watch a sunset on the beach together', done:true  },
      { id:2, text:'Take a spontaneous overnight trip',    done:false },
      { id:3, text:'Get lost in a new city with no plan', done:false },
      { id:4, text:'See the northern lights',             done:false },
      { id:5, text:'Go on a train journey through the mountains', done:false },
      { id:6, text:'Stay in a tiny cabin in the middle of nowhere', done:false },
    ],
    experiences: [
      { id:7,  text:'Cook a fancy 3-course dinner at home',          done:true  },
      { id:8,  text:'Watch all our favorite childhood movies',        done:true  },
      { id:9,  text:'Take a dance class even if we are terrible',     done:false },
      { id:10, text:'Write letters to our future selves',             done:false },
      { id:11, text:'Go stargazing far from the city lights',         done:false },
      { id:12, text:'Plant something together and watch it grow',     done:false },
    ]
  },
  albums: []
};

let D = ls('siteData', DEFAULT_DATA);
function mergeDefaults(obj, def) { for (const k in def) { if (!(k in obj)) obj[k] = def[k]; } return obj; }
D = mergeDefaults(D, DEFAULT_DATA);

// ═══════════════════════════════════════════════════════
//  LOCK SCREEN
// ═══════════════════════════════════════════════════════
const PASS_KEY         = 'us_always_pass';
const SESSION_KEY      = 'us_always_session';
// Hardcoded password — change this to update the passcode
// HARDCODED_PASS is used to decrypt the token on every device automatically
const HARDCODED_PASS   = '112423';
const HARDCODED_HASH   = '85ba58b8131b577f3499c81a6a8ed839f9492471b704a4b5e2bdeb2125bfc238';
// Pre-populate repo config in localStorage
if (!localStorage.getItem('gh_user'))    localStorage.setItem('gh_user',    GH_USER);
if (!localStorage.getItem('gh_repo'))    localStorage.setItem('gh_repo',    GH_REPO);
if (!localStorage.getItem('gh_branch'))  localStorage.setItem('gh_branch',  GH_BRANCH);
if (!localStorage.getItem('gh_gist_id')) localStorage.setItem('gh_gist_id', GH_GIST_ID);
_ghGistId = GH_GIST_ID; // always set in memory
_ghToken  = GH_TOKEN;   // always set in memory from encoded value
// Token is decoded from GH_TOKEN_ENC — no localStorage needed
// Pre-store hardcoded password hash so all devices work without setup
if (!localStorage.getItem('us_always_pass')) localStorage.setItem('us_always_pass', HARDCODED_HASH);

async function hashPass(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str + 'us_always_salt_xo'));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

function isUnlocked()   { return sessionStorage.getItem(SESSION_KEY) === 'yes'; }

// ── AES-GCM encrypt/decrypt using password as key ──
async function deriveKey(password) {
  const enc = new TextEncoder();
  const raw = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']);
  return crypto.subtle.deriveKey(
    { name:'PBKDF2', salt: enc.encode('us_always_salt_aes'), iterations:100000, hash:'SHA-256' },
    raw, { name:'AES-GCM', length:256 }, false, ['encrypt','decrypt']
  );
}
async function encryptToken(token, password) {
  const key = await deriveKey(password);
  const iv  = crypto.getRandomValues(new Uint8Array(12));
  const enc = new TextEncoder();
  const buf = await crypto.subtle.encrypt({ name:'AES-GCM', iv }, key, enc.encode(token));
  // Store as hex iv + ':' + hex ciphertext
  const toHex = b => Array.from(b).map(x=>x.toString(16).padStart(2,'0')).join('');
  return toHex(iv) + ':' + toHex(new Uint8Array(buf));
}
async function decryptToken(encrypted, password) {
  try {
    const [ivHex, ctHex] = encrypted.split(':');
    const fromHex = h => new Uint8Array(h.match(/.{2}/g).map(b=>parseInt(b,16)));
    const key = await deriveKey(password);
    const buf = await crypto.subtle.decrypt({ name:'AES-GCM', iv: fromHex(ivHex) }, key, fromHex(ctHex));
    return new TextDecoder().decode(buf);
  } catch { return null; }
}

async function unlockSite(plainPassword) {
  sessionStorage.setItem(SESSION_KEY, 'yes');
  // Always use hardcoded pass as fallback so token decryption works on all devices
  const plainPassword2 = plainPassword || HARDCODED_PASS;
  sessionStorage.setItem('plain_pass_temp', plainPassword2);
  plainPassword = plainPassword2;

  // Step 1: try to decrypt token from whatever D we have locally cached
  if (plainPassword && D.encryptedToken) {
    const tok = await decryptToken(D.encryptedToken, plainPassword);
    if (tok) {
      let gid1 = '';
      if (D.encryptedGistId) {
        gid1 = await decryptToken(D.encryptedGistId, plainPassword) || '';
      } else if (D.gistId) {
        gid1 = D.gistId;
      }
      storeToken(tok, gid1);
    }
  }

  // Dismiss lock screen
  const ls = document.getElementById('lockScreen');
  if (ls) {
    ls.classList.add('unlocked');
    setTimeout(() => { if (ls.parentNode) ls.parentNode.removeChild(ls); }, 700);
  }

  // Step 2: run init — this fetches fresh data.json from GitHub (public URL)
  // and decrypts the token from it if we don't have one yet
  await init();

  // Step 3: after init, if we have a working token, persist it to localStorage
  // so it survives page refreshes and tab closes on this device
  if (ghReady()) {
    const tok = _ghToken || sessionStorage.getItem('gh_token_s') || localStorage.getItem('gh_token');
    const gid = _ghGistId || sessionStorage.getItem('gh_gist_id_s') || localStorage.getItem('gh_gist_id');
    storeToken(tok, gid);
    setSyncStatus('ok', 'Synced');
    // If Gist data is missing encryptedToken, save it now so future devices can bootstrap
    if (plainPassword && D && !D.encryptedToken) {
      try {
        D.encryptedToken  = await encryptToken(tok, plainPassword);
        D.encryptedGistId = await encryptToken(gid || '', plainPassword);
        D.gistId = gid || '';
        await gistSave(D);
      } catch(e) { /* non-critical */ }
    }
  }

  // GitHub sync bootstraps automatically via gist-pointer.json
}

