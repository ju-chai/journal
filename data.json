function renderBucket() {
  ['travel','experiences'].forEach(cat => {
    const el = document.getElementById('bucket-' + cat); el.innerHTML = '';
    D.bucket[cat].forEach(item => {
      const div = document.createElement('div');
      div.className = 'bucket-item' + (item.done ? ' done' : ''); div.dataset.id = item.id;
      div.innerHTML = '<div class="bucket-check" onclick="toggleBucket(this)"></div>' +
        '<span class="bucket-text" data-editable="block" data-key="bucket_' + item.id + '">' + item.text + '</span>' +
        '<button class="bucket-remove edit-ctrl" onclick="removeBucketItem(\'' + cat + '\',' + item.id + ')"></button>';
      el.appendChild(div);
    });
  });
  applyTexts(); reapplyEditables();
}
function collectBucketEdits() {
  ['travel','experiences'].forEach(cat => {
    D.bucket[cat].forEach(item => {
      const el = document.querySelector('[data-key="bucket_' + item.id + '"]');
      if (el) item.text = el.textContent;
      const row = document.querySelector('#bucket-' + cat + ' [data-id="' + item.id + '"]');
      if (row) item.done = row.classList.contains('done');
    });
  });
}
function toggleBucket(checkEl) {
  const row = checkEl.closest('.bucket-item'); row.classList.toggle('done');
  const id = parseInt(row.dataset.id);
  ['travel','experiences'].forEach(cat => { const f = D.bucket[cat].find(i => i.id===id); if(f) f.done = row.classList.contains('done'); });
  ghSaveData(D);
}
function removeBucketItem(cat, id) {
  D.bucket[cat] = D.bucket[cat].filter(i => i.id !== id);
  renderBucket(); ghSaveData(D);
}
function addBucketItem(cat, inputId) {
  const input = document.getElementById(inputId); const text = input.value.trim(); if (!text) return;
  D.bucket[cat].push({ id:Date.now(), text, done:false });
  renderBucket(); input.value = ''; reapplyEditables(); ghSaveData(D);
}
['addTravel','addExp'].forEach(id => {
  document.getElementById(id).addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); addBucketItem(id==='addTravel'?'travel':'experiences', id); }
  });
});

// ═══════════════════════════════════════════════════════
//  LOVE NOTES
// ═══════════════════════════════════════════════════════
function renderNotes() {
  const grid = document.getElementById('notesGrid'); grid.innerHTML = '';
  D.notes.forEach(note => {
    const card = document.createElement('div'); card.className = 'note-card'; card.dataset.id = note.id;
    card.innerHTML = '<button class="note-remove" onclick="removeNote(' + note.id + ')" title="Delete note">✕</button>' +
      '<span class="note-tag" data-editable data-key="noteTag_' + note.id + '">' + note.tag + '</span>' +
      '<p class="note-text" data-editable="block" data-key="noteText_' + note.id + '">' + note.text + '</p>' +
      '<div class="note-from"><span>from <strong data-editable data-key="noteFrom_' + note.id + '">' + note.from + '</strong></span>' +
      '<span data-editable data-key="noteDate_' + note.id + '">' + note.date + '</span></div>';
    grid.appendChild(card);
  });
  applyTexts(); reapplyEditables();
}
function collectNoteEdits() {
  D.notes.forEach(note => {
    ['noteText_','noteTag_','noteFrom_','noteDate_'].forEach(pfx => {
      const el = document.querySelector('[data-key="' + pfx + note.id + '"]');
      if (!el) return;
      if (pfx==='noteText_') note.text = el.textContent;
      if (pfx==='noteTag_')  note.tag  = el.textContent;
      if (pfx==='noteFrom_') note.from = el.textContent;
      if (pfx==='noteDate_') note.date = el.textContent;
    });
  });
}
function removeNote(id) {
  if (!confirm('Delete this note?')) return;
  D.notes = D.notes.filter(n => n.id !== id);
  renderNotes(); ghSaveData(D);
}
const noteModal = document.getElementById('noteModal');
document.getElementById('openNoteModal').addEventListener('click', () => noteModal.classList.add('open'));
document.getElementById('closeNoteModal').addEventListener('click', () => noteModal.classList.remove('open'));
document.getElementById('cancelNote').addEventListener('click', () => noteModal.classList.remove('open'));
noteModal.addEventListener('click', e => { if (e.target === noteModal) noteModal.classList.remove('open'); });
document.getElementById('saveNote').addEventListener('click', async () => {
  const text = document.getElementById('noteText').value.trim(); if (!text) return;
  const note = { id:Date.now(), tag:document.getElementById('noteTag').value, text, from:document.getElementById('noteFrom').value,
    date:new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) };
  D.notes.unshift(note); renderNotes();
  document.getElementById('noteText').value = '';
  noteModal.classList.remove('open'); reapplyEditables();
  await ghSaveData(D);
});

// ═══════════════════════════════════════════════════════
//  GALLERY
// ═══════════════════════════════════════════════════════
// ── ALBUM GALLERY ──────────────────────────────────────────────────────────
function photoSrc(p) { return p.url || p.dataUrl || ''; }

if (!D.albums) D.albums = [];
// Migrate old flat photos array to a single album if needed
if (D.photos && D.photos.length && !D.albums.length) {
  D.albums = [{ id: Date.now(), title: 'Our memories', date: '', tag: 'all', photos: D.photos }];
}

let currentAlbumId = null;
const PHOTOS_PER_PAGE = 12;
let albumPage = 1;

function renderGallery() {
  const albumsGrid = document.getElementById('albumsGrid');
  const openView   = document.getElementById('albumOpenView');
  const empty      = document.getElementById('galleryEmpty');

  if (currentAlbumId === null) {
    albumsGrid.style.display = '';
    openView.classList.remove('active');
    albumsGrid.querySelectorAll('.album-card').forEach(el => el.remove());
    const albums = D.albums || [];
    empty.style.display = albums.length === 0 ? 'block' : 'none';
    if (!albumsGrid.contains(empty)) albumsGrid.appendChild(empty);
    albums.forEach(album => {
      albumsGrid.insertBefore(makeAlbumCard(album), empty);
    });
  } else {
    albumsGrid.style.display = 'none';
    openView.classList.add('active');
    renderAlbumPhotos();
  }
}

function makeAlbumCard(album) {
  const card  = document.createElement('div');
  card.className = 'album-card';
  const cover = album.photos && album.photos.length ? photoSrc(album.photos[0]) : '';
  const count = album.photos ? album.photos.length : 0;
  card.innerHTML =
    '<div class="album-cover-wrap">' +
      (cover
        ? '<img src="' + cover + '" alt="' + (album.title||'') + '" loading="lazy"/>'
        : '<div style="width:100%;height:100%;background:var(--blush);display:flex;align-items:center;justify-content:center;font-size:32px;color:var(--rose);">♡</div>') +
      '<span class="album-count">' + count + ' photo' + (count !== 1 ? 's' : '') + '</span>' +
      '<button class="album-delete edit-ctrl" title="Delete album">✕</button>' +
    '</div>' +
    '<div class="album-info">' +
      '<div class="album-title">' + (album.title || 'Untitled album') + '</div>' +
      (album.date ? '<div class="album-date">' + album.date + '</div>' : '') +
    '</div>';
  card.querySelector('.album-cover-wrap').addEventListener('click', () => {
    if (!card.querySelector('.album-cover-wrap').querySelector('.album-delete').matches(':hover')) {
      openAlbum(album.id);
    }
  });
  card.querySelector('.album-info').addEventListener('click', () => openAlbum(album.id));
  card.querySelector('.album-delete').addEventListener('click', (e) => {
    e.stopPropagation();
    if (!confirm('Delete this entire album and all its photos?')) return;
    D.albums = (D.albums || []).filter(a => a.id !== album.id);
    ghSaveData(D);
    renderGallery();
  });
  return card;
}

function openAlbum(albumId) {
  currentAlbumId = albumId;
  albumPage = 1;
  const album = (D.albums || []).find(a => a.id === albumId);
  if (!album) return;
  document.getElementById('albumOpenTitle').textContent = album.title || 'Untitled album';
  document.getElementById('albumOpenMeta').textContent =
    (album.date ? album.date + ' · ' : '') + (album.photos ? album.photos.length : 0) + ' photos';
  renderGallery();
}

function renderAlbumPhotos() {
  const album  = (D.albums || []).find(a => a.id === currentAlbumId);
  if (!album) return;
  const grid   = document.getElementById('albumPhotosGrid');
  const pagDiv = document.getElementById('albumPagination');
  grid.innerHTML = '';
  const photos     = album.photos || [];
  const totalPages = Math.max(1, Math.ceil(photos.length / PHOTOS_PER_PAGE));
  if (albumPage > totalPages) albumPage = totalPages;
  const pagePhotos = photos.slice((albumPage-1)*PHOTOS_PER_PAGE, albumPage*PHOTOS_PER_PAGE);
  pagePhotos.forEach((photo, idx) => {
    const item = document.createElement('div');
    item.className = 'album-photo-item';
    item.innerHTML = '<img src="' + photoSrc(photo) + '" alt="" loading="lazy"/>' +
      '<div class="album-photo-label">' +
        '<span class="album-photo-label-text">' + (album.title || '') + '</span>' +
        (album.date ? '<span class="album-photo-label-date">' + album.date + '</span>' : '') +
      '</div>';
    item.addEventListener('click', () => openAlbumLightbox(album, (albumPage-1)*PHOTOS_PER_PAGE + idx));
    grid.appendChild(item);
  });
  // Pagination
  pagDiv.innerHTML = '';
  if (totalPages <= 1) return;
  const prev = document.createElement('button');
  prev.className = 'page-btn prev-next'; prev.textContent = '← Prev'; prev.disabled = albumPage === 1;
  prev.addEventListener('click', () => { albumPage--; renderAlbumPhotos(); grid.scrollIntoView({behavior:'smooth',block:'start'}); });
  pagDiv.appendChild(prev);
  for (let i = 1; i <= totalPages; i++) {
    if (i===1||i===totalPages||(i>=albumPage-2&&i<=albumPage+2)){
      const btn=document.createElement('button');
      btn.className='page-btn'+(i===albumPage?' active':'');
      btn.textContent=i;
      btn.addEventListener('click',()=>{albumPage=i;renderAlbumPhotos();grid.scrollIntoView({behavior:'smooth',block:'start'});});
      pagDiv.appendChild(btn);
    } else if(i===albumPage-3||i===albumPage+3){
      const d=document.createElement('span');d.textContent='…';d.style.cssText='color:var(--muted);font-size:13px;padding:0 4px;';pagDiv.appendChild(d);
    }
  }
  const next = document.createElement('button');
  next.className = 'page-btn prev-next'; next.textContent = 'Next →'; next.disabled = albumPage === totalPages;
  next.addEventListener('click', () => { albumPage++; renderAlbumPhotos(); grid.scrollIntoView({behavior:'smooth',block:'start'}); });
  pagDiv.appendChild(next);
}

document.getElementById('albumBackBtn').addEventListener('click', () => {
  currentAlbumId = null;
  renderGallery();
  document.getElementById('gallery').scrollIntoView({behavior:'smooth', block:'start'});
});

// Filter buttons filter albums by tag
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    currentAlbumId = null;
    const albumsGrid = document.getElementById('albumsGrid');
    const empty      = document.getElementById('galleryEmpty');
    albumsGrid.querySelectorAll('.album-card').forEach(el => el.remove());
    const filtered = filter === 'all' ? (D.albums||[]) : (D.albums||[]).filter(a => a.tag === filter);
    empty.style.display = filtered.length === 0 ? 'block' : 'none';
    if (!albumsGrid.contains(empty)) albumsGrid.appendChild(empty);
    filtered.forEach(album => albumsGrid.insertBefore(makeAlbumCard(album), empty));
  });
});

const uploadModal  = document.getElementById('uploadModal');
const dropZone     = document.getElementById('dropZone');
const fileInput    = document.getElementById('photoFileInput');
const previewStrip = document.getElementById('previewStrip');
let stagedFiles = [];

function openUploadModal()  { uploadModal.classList.add('open'); stagedFiles = []; previewStrip.innerHTML = ''; }
function closeUploadModal() { uploadModal.classList.remove('open'); stagedFiles = []; previewStrip.innerHTML = ''; }
document.getElementById('openUploadModal').addEventListener('click', openUploadModal);
document.getElementById('closeUploadModal').addEventListener('click', closeUploadModal);
document.getElementById('cancelUpload').addEventListener('click', closeUploadModal);
uploadModal.addEventListener('click', e => { if (e.target === uploadModal) closeUploadModal(); });
dropZone.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', e => handleFiles(Array.from(e.target.files)));
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('dragover'); handleFiles(Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'))); });

function handleFiles(files) {
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = ev => {
      const dataUrl = ev.target.result; const id = Date.now() + Math.random();
      stagedFiles.push({ id, dataUrl });
      const thumb = document.createElement('div'); thumb.className = 'preview-thumb'; thumb.dataset.id = id;
      thumb.innerHTML = '<img src="' + dataUrl + '" alt="preview"/><button class="rm">x</button>';
      thumb.querySelector('.rm').addEventListener('click', ev2 => { ev2.stopPropagation(); stagedFiles = stagedFiles.filter(f => f.id != id); thumb.remove(); });
      previewStrip.appendChild(thumb);
    };
    reader.readAsDataURL(file);
  });
}

document.getElementById('savePhotos').addEventListener('click', async () => {
  if (!stagedFiles.length) { alert('Please choose at least one photo first.'); return; }
  const title = document.getElementById('photoCaption').value.trim() || 'Album ' + new Date().toLocaleDateString('en-US',{month:'long',year:'numeric'});
  const date  = document.getElementById('photoDate').value.trim();
  const tag   = document.getElementById('photoTag').value;
  const prog  = document.getElementById('uploadProgress');
  const fill  = document.getElementById('progressFill');
  const txt   = document.getElementById('progressText');
  prog.classList.add('show');
  // Create a new album
  const album = { id: Date.now(), title, date, tag, photos: [] };
  let saved = 0;
  for (const staged of stagedFiles) {
    const compressed = await new Promise(res => compressImage(staged.dataUrl, 1200, .82, res));
    const filename   = 'photo_' + Date.now() + '_' + Math.floor(Math.random()*10000) + '.jpg';
    const photoObj   = await ghSavePhoto(filename, compressed, title, date, tag);
    album.photos.push(photoObj); saved++;
    fill.style.width = Math.round(saved / stagedFiles.length * 100) + '%';
    txt.textContent  = 'Uploading ' + saved + ' of ' + stagedFiles.length + '…';
  }
  if (!D.albums) D.albums = [];
  D.albums.unshift(album);
  await ghSaveData(D); renderGallery();
  setTimeout(() => {
    prog.classList.remove('show'); fill.style.width='0%';
    closeUploadModal();
    document.getElementById('photoCaption').value='';
    document.getElementById('photoDate').value='';
  }, 400);
});

function compressImage(dataUrl, maxW, quality, cb) {
  const img = new Image();
  img.onload = () => {
    const scale = Math.min(1, maxW / img.width);
    const cv = document.createElement('canvas');
    cv.width = Math.round(img.width * scale); cv.height = Math.round(img.height * scale);
    cv.getContext('2d').drawImage(img, 0, 0, cv.width, cv.height);
    cb(cv.toDataURL('image/jpeg', quality));
  };
  img.src = dataUrl;
}

const lightbox = document.getElementById('lightbox');
const lbImg    = document.getElementById('lbImg');
let lbIndex    = 0;
// Album-aware lightbox
let lbAlbumPhotos = [];
function openAlbumLightbox(album, startIdx) {
  lbAlbumPhotos = album.photos || [];
  lbIndex = startIdx;
  showLbSlide(lbAlbumPhotos, lbIndex);
  document.getElementById('lbDelete').style.display = '';
  document.getElementById('lbPrev').style.display = '';
  document.getElementById('lbNext').style.display = '';
  lightbox.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function showLbSlide(list, idx) {
  const p = list[idx]; if (!p) return;
  lbImg.src = photoSrc(p);
  document.getElementById('lbCaption').textContent = p.caption || '';
  document.getElementById('lbMeta').textContent = p.date || '';
  document.getElementById('lbCounter').textContent = (idx+1) + ' / ' + list.length;
}
function closeLightbox() {
  lightbox.classList.remove('open');
  document.body.style.overflow = '';
  lbImg.src = '';
  // Restore nav buttons in case they were hidden by timeline photo viewer
  document.getElementById('lbDelete').style.display = '';
  document.getElementById('lbPrev').style.display = '';
  document.getElementById('lbNext').style.display = '';
}
document.getElementById('lbClose').addEventListener('click', closeLightbox);
lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
document.getElementById('lbPrev').addEventListener('click', () => { lbIndex = (lbIndex - 1 + lbAlbumPhotos.length) % lbAlbumPhotos.length; showLbSlide(lbAlbumPhotos, lbIndex); });
document.getElementById('lbNext').addEventListener('click', () => { lbIndex = (lbIndex + 1) % lbAlbumPhotos.length; showLbSlide(lbAlbumPhotos, lbIndex); });
document.addEventListener('keydown', e => { if (!lightbox.classList.contains('open')) return; if (e.key==='ArrowLeft') document.getElementById('lbPrev').click(); if (e.key==='ArrowRight') document.getElementById('lbNext').click(); if (e.key==='Escape') closeLightbox(); });
document.getElementById('lbDelete').addEventListener('click', async () => {
  if (!confirm('Remove this photo?')) return;
  const photo = lbAlbumPhotos[lbIndex];
  if (!photo) return;
  // Remove from the current album
  const album = (D.albums || []).find(a => a.id === currentAlbumId);
  if (album) album.photos = album.photos.filter(p => p.id != photo.id);
  lbAlbumPhotos = lbAlbumPhotos.filter(p => p.id != photo.id);
  await ghSaveData(D);
  renderAlbumPhotos();
  if (!lbAlbumPhotos.length) { closeLightbox(); return; }
  lbIndex = Math.min(lbIndex, lbAlbumPhotos.length - 1);
  showLbSlide(lbAlbumPhotos, lbIndex);
});

// ═══════════════════════════════════════════════════════
//  SCROLL FADE-IN
// ═══════════════════════════════════════════════════════
const observer = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: .12 });
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) {
  document.querySelectorAll('.petal').forEach(p => p.style.animationPlayState = 'paused');
  // Disable parallax too
  window.removeEventListener('scroll', () => {});
}
</script>

<!-- TOAST -->
<div id="toast"></div>

</body>
