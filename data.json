// ── PARALLAX ──────────────────────────────────────────────────────
(function initParallax() {
  const heroContent = document.querySelector('#hero .hero-bg-petals');
  const heroTitle   = document.querySelector('.hero-title');
  const heroSub     = document.querySelector('.hero-subtitle');
  const heroEye     = document.querySelector('.hero-eyebrow');
  const counter     = document.querySelector('.counter-wrap');
  const annRow      = document.querySelector('.anniversary-row');

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (ticking) return;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      if (heroContent) heroContent.style.transform  = 'translateY(' + (y * 0.4)  + 'px)';
      if (heroTitle)   heroTitle.style.transform    = 'translateY(' + (y * 0.25) + 'px)';
      if (heroSub)     heroSub.style.transform      = 'translateY(' + (y * 0.2)  + 'px)';
      if (heroEye)     heroEye.style.transform      = 'translateY(' + (y * 0.15) + 'px)';
      if (counter)     counter.style.transform      = 'translateY(' + (y * 0.18) + 'px)';
      if (annRow)      annRow.style.transform       = 'translateY(' + (y * 0.15) + 'px)';
      ticking = false;
    });
    ticking = true;
  }, { passive: true });
})();



