// ── Set / Change password modal ──
document.getElementById('cancelSetPass').addEventListener('click', () => {
  document.getElementById('setPasswordModal').classList.remove('open');
});

document.getElementById('confirmSetPass').addEventListener('click', async () => {
  const p1  = document.getElementById('newPass1').value;
  const p2  = document.getElementById('newPass2').value;
  const err = document.getElementById('setPassError');
  if (!p1)           { err.textContent = 'Please enter a password.';      return; }
  if (p1.length < 4) { err.textContent = 'At least 4 characters please.'; return; }
  if (p1 !== p2)     { err.textContent = "Passwords don't match.";         return; }
  localStorage.setItem(PASS_KEY, await hashPass(p1));
  err.textContent = '';
  document.getElementById('newPass1').value = '';
  document.getElementById('newPass2').value = '';
  document.getElementById('setPasswordModal').classList.remove('open');
  // Store plain password temporarily in sessionStorage so unlockSite can use it
  sessionStorage.setItem('plain_pass_temp', p1);
  unlockSite(p1);
});

// ── Main lock logic ──
if (isUnlocked()) {
  unlockSite();
} else {
  const hasPass = !!localStorage.getItem(PASS_KEY);
  if (!hasPass) {
    // No password in storage — use hardcoded hash (already pre-stored above)
    // Nothing to show — passcode screen works immediately
  }

  // ── PASSCODE KEYPAD ──
  let passcodeEntered = '';

  function updateDots() {
    for (let i = 0; i < 6; i++) {
      const dot = document.getElementById('pd' + i);
      if (dot) dot.classList.toggle('filled', i < passcodeEntered.length);
    }
  }

  async function tryUnlock() {
    const val = passcodeEntered;
    if (val.length < 6) return;
    const hashed = await hashPass(val);
    const storedHash = localStorage.getItem(PASS_KEY) || HARDCODED_HASH;
    if (hashed === storedHash) {
      document.getElementById('lockError').textContent = '';
      unlockSite(HARDCODED_PASS);
    } else {
      document.querySelectorAll('.passcode-dot').forEach(d => {
        d.classList.remove('shake'); void d.offsetWidth; d.classList.add('shake');
        setTimeout(() => d.classList.remove('shake'), 400);
      });
      document.getElementById('lockError').textContent = 'Wrong passcode — try again';
      setTimeout(() => {
        passcodeEntered = '';
        updateDots();
        document.getElementById('lockError').textContent = '';
      }, 700);
    }
  }

  function addTapHandler(el, fn) {
    // Use touchend for snappy mobile response, fall back to click on desktop
    let touched = false;
    el.addEventListener('touchend', (e) => {
      e.preventDefault();
      touched = true;
      fn();
      setTimeout(() => { touched = false; }, 300);
    }, { passive: false });
    el.addEventListener('click', () => { if (!touched) fn(); });
  }

  document.querySelectorAll('.passcode-key[data-n]').forEach(key => {
    addTapHandler(key, async () => {
      if (passcodeEntered.length >= 6) return;
      passcodeEntered += key.dataset.n;
      updateDots();
      if (passcodeEntered.length === 6) await tryUnlock();
    });
  });

  addTapHandler(document.getElementById('passcodeDelBtn'), () => {
    passcodeEntered = passcodeEntered.slice(0, -1);
    updateDots();
    document.getElementById('lockError').textContent = '';
  });

  // Setup link removed — password is hardcoded

  updateDots();
}

