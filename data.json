<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Us, Always</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<!-- App icon for iPhone/iPad home screen -->
<link rel="apple-touch-icon" href="data:image/png;base64,"/>
<link rel="icon" type="image/png" href="data:image/png;base64,"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="apple-mobile-web-app-title" content="Us, Always"/>
<meta name="mobile-web-app-capable" content="yes"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ivory:#fdf8f4;--cream:#f5ede5;--blush:#f0ddd5;
  --rose:#c9857a;--roseDark:#a3635a;--walnut:#3a2520;
  --warm:#7a4f3a;--muted:#9e7d72;--sage:#8a9e8c;--sagePale:#d4e0d5;
  --border:rgba(58,37,32,0.1);
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
}
html{scroll-behavior:smooth;}
body{font-family:var(--sans);background:var(--ivory);color:var(--walnut);font-size:15px;line-height:1.65;overflow-x:hidden;}
img{width:100%;height:100%;object-fit:cover;display:block;border-radius:inherit;}
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:var(--cream);}
::-webkit-scrollbar-thumb{background:var(--blush);border-radius:10px;}

/* ── LOCK SCREEN ── */
#lockScreen{position:fixed;inset:0;z-index:9999;background:linear-gradient(135deg,#fdf8f4 0%,#f9ede6 25%,#fdf3ef 50%,#f5e8e0 75%,#fdf8f4 100%);background-size:400% 400%;animation:gradientShift 12s ease infinite;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;transition:opacity .6s ease,visibility .6s ease;}
#lockScreen.unlocked{opacity:0;visibility:hidden;pointer-events:none;}
.lock-petals{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.lock-eyebrow{font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--sage);margin-bottom:1rem;font-weight:400;}
.lock-title{font-family:var(--serif);font-size:clamp(38px,7vw,72px);font-weight:300;color:var(--walnut);line-height:1.1;text-align:center;margin-bottom:.5rem;}
.lock-title em{font-style:italic;color:var(--rose);}
.lock-sub{font-size:13px;color:var(--muted);font-weight:300;letter-spacing:.04em;text-align:center;margin-bottom:2.5rem;}
.lock-divider{display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem;}
.lock-divider .line{width:50px;height:.5px;background:var(--rose);opacity:.4;}
.lock-divider .diamond{width:5px;height:5px;background:var(--rose);transform:rotate(45deg);opacity:.6;}
.lock-form{display:flex;flex-direction:column;align-items:center;gap:1rem;width:100%;max-width:300px;}
.lock-input-wrap{position:relative;width:100%;}
.lock-input{width:100%;font-family:var(--sans);font-size:15px;padding:.85rem 3rem .85rem 1.2rem;border:1px solid var(--border);border-radius:100px;background:white;color:var(--walnut);text-align:center;letter-spacing:.15em;outline:none;transition:border-color .2s,box-shadow .2s;}
.lock-input:focus{border-color:var(--rose);box-shadow:0 0 0 3px rgba(201,133,122,.12);}
.lock-input.shake{animation:shake .4s ease;}
.lock-input::placeholder{letter-spacing:.08em;color:var(--blush);}
.lock-toggle{position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;padding:4px;}
.lock-btn{width:100%;padding:.85rem;background:var(--rose);border:none;border-radius:100px;color:white;font-family:var(--sans);font-size:13px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;transition:background .2s,transform .1s;}
.lock-btn:hover{background:var(--roseDark);}
.lock-btn:active{transform:scale(.98);}
.lock-error{font-size:12px;color:var(--rose);letter-spacing:.04em;height:16px;text-align:center;}
.lock-hint{font-size:11px;color:var(--muted);text-align:center;margin-top:.5rem;letter-spacing:.03em;}
.lock-hint a{color:var(--rose);text-decoration:none;cursor:pointer;}
.lock-hint a:hover{text-decoration:underline;}
@keyframes shake{0%,100%{transform:translateX(0);}20%{transform:translateX(-8px);}40%{transform:translateX(8px);}60%{transform:translateX(-5px);}80%{transform:translateX(5px);}}

/* ── PASSCODE ── */
.passcode-dots{display:flex;gap:18px;justify-content:center;margin:1.5rem 0 .5rem;}
.passcode-dot{width:14px;height:14px;border-radius:50%;border:1.5px solid var(--rose);background:transparent;transition:background .15s ease,transform .1s ease;}
.passcode-dot.filled{background:var(--rose);transform:scale(1.1);}
.passcode-dot.shake{animation:shake .4s ease;}
.passcode-error{font-size:12px;color:var(--rose);letter-spacing:.06em;height:18px;text-align:center;margin-bottom:.8rem;}
.passcode-keypad{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;width:min(260px,80vw);margin:0 auto;}
.passcode-keypad{position:relative;z-index:2;}
.passcode-dots{position:relative;z-index:2;}
.passcode-key{width:72px;height:72px;border-radius:50%;border:1px solid rgba(201,133,122,.3);background:rgba(253,248,244,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:background .15s,transform .1s;margin:0 auto;-webkit-tap-highlight-color:transparent;position:relative;z-index:2;touch-action:manipulation;user-select:none;-webkit-user-select:none;}
.passcode-key:active{background:rgba(201,133,122,.25);transform:scale(.94);}
.passcode-key.empty{background:transparent;border:none;cursor:default;pointer-events:none;}
.passcode-key-num{font-family:var(--sans);font-size:24px;font-weight:300;color:var(--walnut);line-height:1;}
.passcode-key-letters{font-size:9px;letter-spacing:.12em;color:var(--muted);margin-top:2px;}
.passcode-del{font-size:20px;color:var(--muted);}


/* ── LOCK SCREEN ── */
#lockScreen{position:fixed;inset:0;z-index:9999;background:linear-gradient(135deg,#fdf8f4 0%,#f9ede6 25%,#fdf3ef 50%,#f5e8e0 75%,#fdf8f4 100%);background-size:400% 400%;animation:gradientShift 12s ease infinite;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;transition:opacity .6s ease,visibility .6s ease;}
#lockScreen.unlocked{opacity:0;visibility:hidden;pointer-events:none;}
.lock-petals{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.lock-eyebrow{font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--sage);margin-bottom:1rem;font-weight:400;}
.lock-title{font-family:var(--serif);font-size:clamp(38px,7vw,72px);font-weight:300;color:var(--walnut);line-height:1.1;text-align:center;margin-bottom:.5rem;}
.lock-title em{font-style:italic;color:var(--rose);}
.lock-sub{font-size:13px;color:var(--muted);font-weight:300;letter-spacing:.04em;text-align:center;margin-bottom:2.5rem;}
.lock-divider{display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem;}
.lock-divider .line{width:50px;height:.5px;background:var(--rose);opacity:.4;}
.lock-divider .diamond{width:5px;height:5px;background:var(--rose);transform:rotate(45deg);opacity:.6;}
.lock-form{display:flex;flex-direction:column;align-items:center;gap:1rem;width:100%;max-width:300px;}
.lock-input-wrap{position:relative;width:100%;}
.lock-input{width:100%;font-family:var(--sans);font-size:15px;padding:.85rem 3rem .85rem 1.2rem;border:1px solid var(--border);border-radius:100px;background:white;color:var(--walnut);text-align:center;letter-spacing:.15em;outline:none;transition:border-color .2s,box-shadow .2s;}
.lock-input:focus{border-color:var(--rose);box-shadow:0 0 0 3px rgba(201,133,122,.12);}
.lock-input.shake{animation:shake .4s ease;}
.lock-input::placeholder{letter-spacing:.08em;color:var(--blush);}
.lock-toggle{position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;padding:4px;}
.lock-btn{width:100%;padding:.85rem;background:var(--rose);border:none;border-radius:100px;color:white;font-family:var(--sans);font-size:13px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;transition:background .2s,transform .1s;}
.lock-btn:hover{background:var(--roseDark);}
.lock-btn:active{transform:scale(.98);}
.lock-error{font-size:12px;color:var(--rose);letter-spacing:.04em;height:16px;text-align:center;}
.lock-hint{font-size:11px;color:var(--muted);text-align:center;margin-top:.5rem;letter-spacing:.03em;}
.lock-hint a{color:var(--rose);text-decoration:none;cursor:pointer;}
.lock-hint a:hover{text-decoration:underline;}
@keyframes shake{0%,100%{transform:translateX(0);}20%{transform:translateX(-8px);}40%{transform:translateX(8px);}60%{transform:translateX(-5px);}80%{transform:translateX(5px);}}

/* ── PASSCODE ── */
.passcode-dots{display:flex;gap:18px;justify-content:center;margin:1.5rem 0 .5rem;}
.passcode-dot{width:14px;height:14px;border-radius:50%;border:1.5px solid var(--rose);background:transparent;transition:background .15s ease,transform .1s ease;}
.passcode-dot.filled{background:var(--rose);transform:scale(1.1);}
.passcode-dot.shake{animation:shake .4s ease;}
.passcode-error{font-size:12px;color:var(--rose);letter-spacing:.06em;height:18px;text-align:center;margin-bottom:.8rem;}
.passcode-keypad{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;width:min(260px,80vw);margin:0 auto;}
.passcode-keypad{position:relative;z-index:2;}
.passcode-dots{position:relative;z-index:2;}
.passcode-key{width:72px;height:72px;border-radius:50%;border:1px solid rgba(201,133,122,.3);background:rgba(253,248,244,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:background .15s,transform .1s;margin:0 auto;-webkit-tap-highlight-color:transparent;position:relative;z-index:2;touch-action:manipulation;user-select:none;-webkit-user-select:none;}
.passcode-key:active{background:rgba(201,133,122,.25);transform:scale(.94);}
.passcode-key.empty{background:transparent;border:none;cursor:default;pointer-events:none;}
.passcode-key-num{font-family:var(--sans);font-size:24px;font-weight:300;color:var(--walnut);line-height:1;}
.passcode-key-letters{font-size:9px;letter-spacing:.12em;color:var(--muted);margin-top:2px;}
.passcode-del{font-size:20px;color:var(--muted);}


/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 2rem;height:60px;background:rgba(253,248,244,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:var(--serif);font-style:italic;font-size:22px;color:var(--warm);letter-spacing:.02em;text-decoration:none;}
.nav-links{display:flex;gap:1.5rem;list-style:none;align-items:center;}
.nav-links a{font-size:11px;font-weight:400;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s;}
.nav-links a:hover{color:var(--warm);}
.nav-right{display:flex;align-items:center;gap:.6rem;}

.btn-edit-mode{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:100px;border:1px solid var(--border);background:transparent;font-family:var(--sans);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);cursor:pointer;transition:all .2s;}
.btn-edit-mode:hover{border-color:var(--rose);color:var(--rose);}
.btn-edit-mode.active{background:var(--rose);border-color:var(--rose);color:white;}
.nav-toggle{display:none;background:none;border:none;cursor:pointer;flex-direction:column;gap:5px;padding:4px;}
.nav-toggle span{display:block;width:22px;height:1.5px;background:var(--warm);border-radius:2px;}



/* ── EDIT MODE ── */
body.editing [data-editable]{outline:1.5px dashed rgba(201,133,122,.5);border-radius:3px;cursor:text;min-width:20px;display:inline-block;}
body.editing [data-editable]:hover{outline-color:var(--rose);background:rgba(201,133,122,.05);}
body.editing [data-editable]:focus{outline:1.5px solid var(--rose);background:rgba(201,133,122,.07);}
body.editing [data-editable="block"]{display:block;}
.edit-ctrl{display:none;}
body.editing .edit-ctrl{display:inline-flex;}
#editBanner{display:none;position:fixed;bottom:1.4rem;left:50%;transform:translateX(-50%);z-index:500;background:var(--walnut);color:white;padding:.55rem 1.4rem;border-radius:100px;font-size:12px;letter-spacing:.06em;white-space:nowrap;pointer-events:none;box-shadow:0 4px 20px rgba(58,37,32,.3);}
body.editing #editBanner{display:block;}

/* ── HERO ── */
#hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:5rem 2rem 3rem;position:relative;overflow:hidden;background:linear-gradient(135deg,#fdf8f4 0%,#f9ede6 25%,#fdf3ef 50%,#f5e8e0 75%,#fdf8f4 100%);background-size:400% 400%;animation:gradientShift 12s ease infinite;}
@keyframes gradientShift{0%{background-position:0% 50%;}50%{background-position:100% 50%;}100%{background-position:0% 50%;}}
.hero-bg-petals{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.petal{position:absolute;opacity:0;animation:fall linear infinite;pointer-events:none !important;}
.petal.type-petal{width:7px;height:7px;border-radius:50% 50% 50% 0;background:var(--blush);}
.petal.type-heart{width:8px;height:8px;background:none;color:var(--rose);font-size:9px;line-height:1;}
.petal.type-circle{width:4px;height:4px;border-radius:50%;background:var(--sagePale);}
@keyframes fall{
  0%  {transform:translateY(-30px) rotate(0deg)   translateX(0);      opacity:0;}
  10% {opacity:.7;}
  90% {opacity:.4;}
  100%{transform:translateY(110vh) rotate(720deg) translateX(40px);   opacity:0;}
}
.hero-eyebrow{font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--sage);margin-bottom:1.2rem;font-weight:400;}
.hero-title{font-family:var(--serif);font-size:clamp(46px,9vw,90px);font-weight:300;color:var(--walnut);line-height:1.05;margin-bottom:1rem;}
.hero-title em{font-style:italic;color:var(--rose);}
.hero-subtitle{font-size:14px;color:var(--muted);font-weight:300;letter-spacing:.04em;margin-bottom:2.5rem;}
.divider-line{display:flex;align-items:center;gap:1.2rem;margin-bottom:2.5rem;justify-content:center;}
.divider-line .line{width:60px;height:.5px;background:var(--rose);opacity:.5;}
.divider-line .diamond{width:6px;height:6px;background:var(--rose);transform:rotate(45deg);opacity:.7;}
.counter-wrap{display:flex;gap:1.5rem;justify-content:center;margin-bottom:2.5rem;flex-wrap:wrap;}
.counter-block{display:flex;flex-direction:column;align-items:center;}
.counter-num{font-family:var(--serif);font-size:clamp(36px,6vw,58px);font-weight:300;color:var(--warm);line-height:1;min-width:1.8ch;text-align:center;}
.counter-label{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-top:4px;}
.counter-sep{font-family:var(--serif);font-size:40px;color:var(--blush);align-self:center;line-height:1;padding-bottom:10px;}
.heartbeat{display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;border:1px solid var(--rose);color:var(--rose);font-size:18px;animation:pulse 2.2s ease-in-out infinite;text-decoration:none;margin-top:.5rem;}
@keyframes pulse{0%,100%{transform:scale(1);box-shadow:0 0 0 0 rgba(201,133,122,.3);}50%{transform:scale(1.08);box-shadow:0 0 0 10px rgba(201,133,122,0);}}
.scroll-hint{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;color:var(--muted);font-size:10px;letter-spacing:.15em;text-transform:uppercase;animation:bob 2s ease-in-out infinite;}
.scroll-hint::after{content:'';display:block;width:1px;height:36px;background:linear-gradient(to bottom,var(--rose),transparent);}
@keyframes bob{0%,100%{transform:translateX(-50%) translateY(0);}50%{transform:translateX(-50%) translateY(6px);}}
/* Parallax */
.hero-parallax{will-change:transform;transition:transform .05s linear;}
.anniversary-row{display:flex;align-items:center;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;}
.anniversary-label{font-family:var(--serif);font-style:italic;font-size:15px;color:var(--muted);}

/* ── SECTIONS ── */
.section{padding:6rem 2rem;max-width:1100px;margin:0 auto;}
.section-label{font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--sage);margin-bottom:.6rem;}
.section-heading{font-family:var(--serif);font-size:clamp(32px,5vw,52px);font-weight:300;color:var(--walnut);line-height:1.1;margin-bottom:2.5rem;}
.section-heading em{font-style:italic;color:var(--rose);}
.full-bleed{background:var(--cream);}

/* ── GALLERY ── */
.gallery-actions{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;flex-wrap:wrap;}
.btn-upload{display:inline-flex;align-items:center;gap:.5rem;padding:.6rem 1.4rem;background:var(--rose);border:1px solid var(--rose);border-radius:100px;color:white;font-family:var(--sans);font-size:12px;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s;}
.btn-upload:hover{background:var(--roseDark);}
.gallery-filter{display:flex;gap:.5rem;flex-wrap:wrap;}
.filter-btn{font-family:var(--sans);font-size:11px;letter-spacing:.1em;text-transform:uppercase;padding:6px 16px;border-radius:100px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;}
.filter-btn:hover,.filter-btn.active{background:var(--rose);border-color:var(--rose);color:white;}
/* ── ALBUM GALLERY ── */
/* Albums view */
.albums-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.5rem;
}
@media(max-width:800px){.albums-grid{grid-template-columns:repeat(2,1fr);gap:1.2rem;}}
@media(max-width:480px){.albums-grid{grid-template-columns:repeat(2,1fr);gap:.8rem;}}

.album-card{
  cursor:pointer;
  position:relative;
}
.album-cover-wrap{
  position:relative;
  border-radius:10px;
  overflow:hidden;
  aspect-ratio:1/1;
  background:var(--blush);
  margin-bottom:.75rem;
  transition:transform .35s cubic-bezier(.25,.46,.45,.94),box-shadow .35s ease;
}
.album-card:hover .album-cover-wrap{
  transform:translateY(-4px);
  box-shadow:0 12px 36px rgba(58,37,32,.14);
}
.album-cover-wrap img{
  width:100%;height:100%;
  object-fit:cover;
  display:block;
  transition:transform .5s ease;
}
.album-card:hover .album-cover-wrap img{transform:scale(1.05);}
.album-count{
  position:absolute;
  bottom:.6rem;right:.6rem;
  background:rgba(20,10,8,.6);
  color:white;
  font-size:11px;
  letter-spacing:.06em;
  padding:3px 9px;
  border-radius:100px;
  backdrop-filter:blur(4px);
}
.album-info{}
.album-title{
  font-family:var(--serif);
  font-style:italic;
  font-size:17px;
  color:var(--walnut);
  line-height:1.2;
  margin-bottom:2px;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.album-date{
  font-size:10px;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--muted);
}
.album-delete{
  position:absolute;
  top:.5rem;right:.5rem;
  width:26px;height:26px;
  border-radius:50%;
  background:rgba(20,10,8,.55);
  border:none;
  color:white;
  font-size:13px;
  cursor:pointer;
  display:none;
  align-items:center;justify-content:center;
  transition:background .2s;
  z-index:2;
}
.album-delete:hover{background:rgba(192,57,43,.85);}
body.editing .album-delete{display:flex;}

/* Album open view (photos inside) */
.album-open-view{
  display:none;
  animation:fadeInUp .4s ease;
}
.album-open-view.active{display:block;}
@keyframes fadeInUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
.album-back-btn{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:12px;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--muted);
  background:none;
  border:none;
  cursor:pointer;
  padding:0;
  margin-bottom:1.5rem;
  transition:color .2s;
}
.album-back-btn:hover{color:var(--warm);}
.album-open-title{
  font-family:var(--serif);
  font-size:32px;
  font-weight:300;
  font-style:italic;
  color:var(--walnut);
  margin-bottom:.3rem;
}
.album-open-meta{
  font-size:11px;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:2rem;
}
/* Photos grid inside open album — polaroid style */
.album-photos-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1.2rem;
}
@media(max-width:700px){.album-photos-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:480px){.album-photos-grid{grid-template-columns:repeat(2,1fr);}}

.album-photo-item{
  background:white;
  padding:8px 8px 44px;
  box-shadow:0 2px 8px rgba(58,37,32,.09);
  border-radius:2px;
  cursor:pointer;
  transform:rotate(var(--tilt,0deg));
  transition:transform .3s ease,box-shadow .3s ease;
  position:relative;
}
.album-photo-item:hover{
  transform:rotate(0deg) translateY(-5px) scale(1.03);
  box-shadow:0 12px 32px rgba(58,37,32,.16);
  z-index:2;
}
.album-photo-item:nth-child(4n+1){--tilt:-1deg;}
.album-photo-item:nth-child(4n+2){--tilt:.8deg;}
.album-photo-item:nth-child(4n+3){--tilt:-.6deg;}
.album-photo-item:nth-child(4n+4){--tilt:1.2deg;}
.album-photo-item img{
  width:100%;aspect-ratio:1/1;object-fit:cover;display:block;
}
.album-photo-label{
  position:absolute;
  bottom:0;left:0;right:0;
  padding:8px 10px 10px;
  text-align:center;
}
.album-photo-label-text{
  font-family:var(--serif);
  font-style:italic;
  font-size:13px;
  color:var(--warm);
  line-height:1.3;
  display:block;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.album-photo-label-date{
  font-size:9px;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--muted);
  margin-top:2px;
  display:block;
}

/* Pagination */
.gallery-pagination{display:flex;align-items:center;justify-content:center;gap:.6rem;margin-top:2.5rem;flex-wrap:wrap;}
.page-btn{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);background:transparent;font-family:var(--sans);font-size:13px;color:var(--muted);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;}
.page-btn:hover{border-color:var(--rose);color:var(--rose);}
.page-btn.active{background:var(--rose);border-color:var(--rose);color:white;}
.page-btn.prev-next{width:auto;padding:0 14px;border-radius:100px;font-size:12px;letter-spacing:.06em;}
.gallery-empty{display:none;text-align:center;padding:3rem 1rem;color:var(--muted);}
.gallery-empty svg{opacity:.3;margin-bottom:.8rem;}

/* ── UPLOAD MODAL ── */
.drop-zone{border:1.5px dashed var(--rose);border-radius:10px;padding:2rem 1rem;text-align:center;cursor:pointer;transition:background .2s;margin-bottom:1rem;}
.drop-zone.dragover{background:rgba(201,133,122,.07);}
.drop-zone input[type="file"]{display:none;}
.drop-zone p{font-size:13px;color:var(--muted);}
.drop-zone strong{color:var(--warm);}
.preview-strip{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1rem;}
.preview-thumb{position:relative;width:68px;height:68px;border-radius:6px;overflow:hidden;flex-shrink:0;}
.preview-thumb img{width:100%;height:100%;object-fit:cover;}
.preview-thumb .rm{position:absolute;top:2px;right:2px;width:17px;height:17px;border-radius:50%;background:rgba(40,20,15,.7);color:white;font-size:10px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.upload-progress{display:none;align-items:center;gap:.6rem;font-size:12px;color:var(--muted);margin-bottom:.8rem;}
.upload-progress.show{display:flex;}
.progress-bar-track{flex:1;height:3px;background:var(--blush);border-radius:10px;overflow:hidden;}
.progress-bar-fill{height:100%;background:var(--rose);border-radius:10px;transition:width .3s;width:0%;}

/* ── LIGHTBOX ── */
#lightbox{display:none;position:fixed;inset:0;z-index:300;background:rgba(20,10,8,.93);align-items:center;justify-content:center;flex-direction:column;padding:1rem;}
#lightbox.open{display:flex;}
#lightbox img{max-width:min(90vw,860px);max-height:72vh;object-fit:contain;border-radius:6px;display:block;width:auto;height:auto;}
.lb-caption{font-family:var(--serif);font-style:italic;font-size:18px;color:rgba(255,255,255,.85);margin-top:1.2rem;text-align:center;}
.lb-meta{font-size:11px;color:rgba(255,255,255,.4);margin-top:.3rem;letter-spacing:.1em;text-transform:uppercase;}
.lb-close{position:absolute;top:1.2rem;right:1.4rem;background:none;border:none;color:rgba(255,255,255,.5);font-size:28px;cursor:pointer;line-height:1;}
.lb-close:hover{color:white;}
.lb-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.1);border:none;color:white;width:44px;height:44px;border-radius:50%;font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;}
.lb-nav:hover{background:rgba(255,255,255,.2);}
.lb-prev{left:1.2rem;}.lb-next{right:1.2rem;}
.lb-delete{position:absolute;bottom:1.5rem;right:1.5rem;background:rgba(180,60,50,.7);border:none;color:white;padding:6px 14px;border-radius:100px;font-size:11px;font-family:var(--sans);cursor:pointer;}
.lb-counter{position:absolute;bottom:1.5rem;left:1.5rem;font-size:11px;color:rgba(255,255,255,.3);letter-spacing:.1em;}

/* ── TIMELINE ── */
.timeline{position:relative;padding-left:2rem;}
.timeline::before{content:'';position:absolute;left:0;top:6px;bottom:0;width:1px;background:linear-gradient(to bottom,var(--rose),var(--blush),transparent);}
.tl-item{position:relative;padding-bottom:3rem;padding-left:2rem;}
.tl-item:last-child{padding-bottom:0;}
.tl-dot{position:absolute;left:-2rem;top:5px;transform:translateX(-50%);width:11px;height:11px;border-radius:50%;background:var(--rose);border:2px solid var(--ivory);box-shadow:0 0 0 1px var(--rose);}
.tl-dot.future{background:var(--ivory);border-color:var(--rose);box-shadow:0 0 0 1px var(--blush);}
.tl-year{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--sage);margin-bottom:.3rem;}
.tl-title{font-family:var(--serif);font-size:24px;font-weight:400;color:var(--walnut);margin-bottom:.4rem;}
.tl-desc{font-size:14px;color:var(--muted);font-weight:300;max-width:500px;line-height:1.7;}
.tl-badge{display:inline-block;font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:3px 10px;border-radius:100px;background:var(--sagePale);color:var(--sage);margin-bottom:.5rem;}
.tl-badge.milestone{background:rgba(201,133,122,.12);color:var(--roseDark);}
.tl-remove{background:none;border:none;cursor:pointer;color:var(--blush);font-size:14px;padding:2px 5px;border-radius:4px;transition:color .2s;line-height:1;vertical-align:middle;margin-left:6px;}
.tl-remove:hover{color:#c0392b;}
/* Timeline photo strip */
.tl-photos{display:flex;gap:8px;flex-wrap:wrap;margin-top:1rem;}
.tl-photo{width:80px;height:80px;border-radius:8px;overflow:hidden;flex-shrink:0;background:var(--blush);cursor:pointer;position:relative;}
.tl-photo img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .3s ease;}
.tl-photo:hover img{transform:scale(1.08);}
.tl-photo-empty{width:80px;height:80px;border-radius:8px;border:1.5px dashed var(--rose);display:none;align-items:center;justify-content:center;flex-shrink:0;color:var(--rose);font-size:20px;cursor:pointer;transition:all .2s;}
.tl-photo-empty:hover{background:rgba(201,133,122,.07);}
body.editing .tl-photo-empty{display:flex;}
.tl-photo-upload{display:none;}
.btn-add-tl{display:inline-flex;align-items:center;gap:.5rem;margin-top:2rem;padding:.6rem 1.4rem;background:transparent;border:1px solid var(--rose);border-radius:100px;color:var(--rose);font-family:var(--sans);font-size:12px;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.btn-add-tl:hover{background:var(--rose);color:white;}

/* ── LOVE NOTES ── */
.notes-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.2rem;}
.note-card{background:white;border:1px solid var(--border);border-radius:10px;padding:1.5rem;position:relative;transition:transform .25s,box-shadow .25s;}
.note-card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(58,37,32,.07);}
.note-card::before{content:'\201C';font-family:var(--serif);font-size:60px;color:var(--blush);position:absolute;top:.2rem;left:.8rem;line-height:1;pointer-events:none;}
.note-tag{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);margin-bottom:.8rem;display:block;}
.note-text{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--walnut);line-height:1.5;margin-bottom:1rem;}
.note-from{font-size:12px;color:var(--muted);display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);padding-top:.7rem;}
.note-from strong{color:var(--warm);font-weight:500;}
.note-remove{position:absolute;top:.5rem;right:.6rem;background:none;border:none;font-size:16px;color:var(--muted);cursor:pointer;transition:all .2s;display:none;line-height:1;padding:2px 5px;border-radius:4px;}
body.editing .note-remove{display:block;}
.note-remove:hover{color:#c0392b;background:rgba(192,57,43,.08);}
.note-add-btn{display:flex;align-items:center;gap:.5rem;margin-top:2rem;padding:.75rem 1.5rem;background:transparent;border:1px solid var(--rose);border-radius:100px;color:var(--rose);font-family:var(--sans);font-size:12px;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.note-add-btn:hover{background:var(--rose);color:white;}

/* ── BUCKET LIST ── */
.bucket-cols{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}
@media(max-width:600px){.bucket-cols{grid-template-columns:1fr;}}
.bucket-group h4{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);margin-bottom:.8rem;padding-bottom:.5rem;border-bottom:1px solid var(--border);}
.bucket-item{display:flex;align-items:flex-start;gap:.75rem;padding:.65rem 0;border-bottom:1px solid rgba(58,37,32,.05);}
.bucket-item:last-child{border-bottom:none;}
.bucket-check{width:18px;height:18px;border-radius:50%;border:1.5px solid var(--blush);flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;font-size:9px;color:white;transition:all .2s;cursor:pointer;}
.bucket-item.done .bucket-check{background:var(--sage);border-color:var(--sage);}
.bucket-item.done .bucket-check::after{content:'✓';}
.bucket-text{font-size:14px;color:var(--walnut);font-weight:300;line-height:1.5;flex:1;}
.bucket-item.done .bucket-text{color:var(--muted);text-decoration:line-through;text-decoration-color:var(--sage);}
.bucket-remove{background:none;border:none;color:var(--blush);font-size:13px;cursor:pointer;padding:0 4px;display:none;transition:color .2s;flex-shrink:0;margin-top:3px;}
body.editing .bucket-remove{display:inline;}
.bucket-remove:hover{color:#c0392b;}
.bucket-add-row{display:none;gap:6px;margin-top:.5rem;}
body.editing .bucket-add-row{display:flex;}
.bucket-add-input{flex:1;font-family:var(--sans);font-size:13px;padding:5px 10px;border:1px solid var(--border);border-radius:6px;background:white;color:var(--walnut);outline:none;}
.bucket-add-input:focus{border-color:var(--rose);}
.bucket-add-submit{background:var(--rose);border:none;color:white;padding:5px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-family:var(--sans);}

/* ── MODALS ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(40,20,15,.55);z-index:10000;align-items:center;justify-content:center;padding:1rem;}
.modal-overlay.open{display:flex;}
.modal{background:var(--ivory);border-radius:14px;padding:2rem;width:100%;max-width:480px;position:relative;max-height:90vh;overflow-y:auto;}
.modal h3{font-family:var(--serif);font-size:26px;font-weight:300;margin-bottom:1.2rem;color:var(--walnut);}
.modal label{display:block;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem;}
.modal input,.modal textarea,.modal select{width:100%;font-family:var(--sans);font-size:14px;padding:.6rem .9rem;border:1px solid var(--border);border-radius:6px;background:white;color:var(--walnut);margin-bottom:1rem;resize:vertical;outline:none;}
.modal input:focus,.modal textarea:focus,.modal select:focus{border-color:var(--rose);}
.modal-actions{display:flex;gap:.8rem;justify-content:flex-end;margin-top:.5rem;}
.btn-cancel{padding:.55rem 1.2rem;background:transparent;border:1px solid var(--border);border-radius:100px;color:var(--muted);font-family:var(--sans);font-size:12px;cursor:pointer;}
.btn-save{padding:.55rem 1.4rem;background:var(--rose);border:1px solid var(--rose);border-radius:100px;color:white;font-family:var(--sans);font-size:12px;cursor:pointer;}
.btn-save:hover{background:var(--roseDark);}
.modal-close{position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:20px;color:var(--muted);cursor:pointer;line-height:1;}



/* ── FOOTER ── */
footer{background:var(--walnut);color:rgba(255,255,255,.5);text-align:center;padding:3rem 1rem;}
footer .footer-heart{font-family:var(--serif);font-style:italic;font-size:22px;color:var(--rose);margin-bottom:.5rem;}
footer p{font-size:12px;letter-spacing:.04em;}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  nav{padding:0 1.2rem;}
  .nav-links{display:none;flex-direction:column;gap:.5rem;}
  .nav-links.open{display:flex;position:fixed;top:60px;left:0;right:0;background:var(--ivory);padding:1.5rem;border-bottom:1px solid var(--border);z-index:99;}
  .nav-toggle{display:flex;}
  .section{padding:4rem 1.2rem;}
  .counter-sep{display:none;}
}

/* ── TOAST NOTIFICATION ── */
#toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);z-index:9000;background:var(--walnut);color:white;padding:.65rem 1.6rem;border-radius:100px;font-size:13px;letter-spacing:.04em;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .3s ease,transform .3s ease;box-shadow:0 4px 20px rgba(58,37,32,.3);}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
#toast.success::before{content:'✓  ';}
#toast.error::before{content:'✗  ';}
#toast.saving::before{content:'⏳  ';}

/* ── FADE-IN ── */
.fade-in{opacity:0;transform:translateY(20px);transition:opacity .7s ease,transform .7s ease;}
.fade-in.visible{opacity:1;transform:none;}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-logo" data-editable data-key="siteTitle">us, always ♡</a>
  <ul class="nav-links" id="navLinks">
    <li><a href="#gallery" onclick="closeNav()">Gallery</a></li>
    <li><a href="#timeline" onclick="closeNav()">Timeline</a></li>
    <li><a href="#notes" onclick="closeNav()">Love Notes</a></li>
    <li><a href="#bucket" onclick="closeNav()">Bucket List</a></li>
  </ul>
  <div class="nav-right">


    <!-- Edit toggle -->
    <button class="btn-edit-mode" id="editToggle">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
      Edit
    </button>
    <button class="nav-toggle" id="navToggle" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>



<!-- LOCK SCREEN -->
<div id="lockScreen">
  <div class="lock-petals" id="lockPetals"></div>
  <p class="lock-eyebrow">private · just for us</p>
  <h1 class="lock-title">us,<br><em>always</em> ♡</h1>
  <p class="lock-sub">Enter your passcode</p>
  <div class="lock-divider"><div class="line"></div><div class="diamond"></div><div class="line"></div></div>
  <!-- Passcode dots -->
  <div class="passcode-dots" id="passcodeDots">
    <div class="passcode-dot" id="pd0"></div>
    <div class="passcode-dot" id="pd1"></div>
    <div class="passcode-dot" id="pd2"></div>
    <div class="passcode-dot" id="pd3"></div>
    <div class="passcode-dot" id="pd4"></div>
    <div class="passcode-dot" id="pd5"></div>
  </div>
  <div class="passcode-error" id="lockError"></div>
  <!-- Number pad -->
  <div class="passcode-keypad">
    <div class="passcode-key" data-n="1"><span class="passcode-key-num">1</span><span class="passcode-key-letters"></span></div>
    <div class="passcode-key" data-n="2"><span class="passcode-key-num">2</span><span class="passcode-key-letters">ABC</span></div>
    <div class="passcode-key" data-n="3"><span class="passcode-key-num">3</span><span class="passcode-key-letters">DEF</span></div>
    <div class="passcode-key" data-n="4"><span class="passcode-key-num">4</span><span class="passcode-key-letters">GHI</span></div>
    <div class="passcode-key" data-n="5"><span class="passcode-key-num">5</span><span class="passcode-key-letters">JKL</span></div>
    <div class="passcode-key" data-n="6"><span class="passcode-key-num">6</span><span class="passcode-key-letters">MNO</span></div>
    <div class="passcode-key" data-n="7"><span class="passcode-key-num">7</span><span class="passcode-key-letters">PQRS</span></div>
    <div class="passcode-key" data-n="8"><span class="passcode-key-num">8</span><span class="passcode-key-letters">TUV</span></div>
    <div class="passcode-key" data-n="9"><span class="passcode-key-num">9</span><span class="passcode-key-letters">WXYZ</span></div>
    <div class="passcode-key empty"></div>
    <div class="passcode-key" data-n="0"><span class="passcode-key-num">0</span></div>
    <div class="passcode-key" id="passcodeDelBtn"><span class="passcode-del">⌫</span></div>
  </div>
  <!-- Hidden input still needed for set-password flow -->
  <input id="lockInput" type="hidden" value=""/>
  <p class="lock-hint" style="margin-top:1.5rem;opacity:0;pointer-events:none;">.</p>
</div>

<!-- SET PASSWORD MODAL -->
<div class="modal-overlay" id="setPasswordModal">
  <div class="modal" style="max-width:380px;">
    <h3>Set your password</h3>
    <label>New password</label>
    <input type="password" id="newPass1" placeholder="choose a password" autocomplete="new-password"/>
    <label>Confirm password</label>
    <input type="password" id="newPass2" placeholder="type it again" autocomplete="new-password"/>
    <div style="font-size:12px;color:var(--rose);height:16px;margin-bottom:.8rem;" id="setPassError"></div>
    <div class="modal-actions">
      <button class="btn-cancel" id="cancelSetPass">Cancel</button>
      <button class="btn-save" id="confirmSetPass">Save password</button>
    </div>
  </div>
</div>


<!-- EDIT BANNER -->
<div id="editBanner">✏️ Edit mode — click any text to edit · click Done to save to GitHub</div>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg-petals" id="petals"></div>
  <p class="hero-eyebrow" data-editable data-key="heroEyebrow">our little world</p>
  <h1 class="hero-title">
    <span data-editable data-key="heroLine1">Every moment</span><br>
    with you is <em data-editable data-key="heroLine2">my<br>favorite</em>
  </h1>
  <p class="hero-subtitle" data-editable="block" data-key="heroSub">A private space just for the two of us</p>
  <div class="divider-line"><div class="line"></div><div class="diamond"></div><div class="line"></div></div>
  <div class="counter-wrap">
    <div class="counter-block"><span class="counter-num" id="cnt-years">0</span><span class="counter-label">years</span></div>
    <div class="counter-sep">·</div>
    <div class="counter-block"><span class="counter-num" id="cnt-months">0</span><span class="counter-label">months</span></div>
    <div class="counter-sep">·</div>
    <div class="counter-block"><span class="counter-num" id="cnt-days">0</span><span class="counter-label">days</span></div>
    <div class="counter-sep">·</div>
    <div class="counter-block"><span class="counter-num" id="cnt-hours">0</span><span class="counter-label">hours</span></div>
  </div>
  <div class="anniversary-row">
    <span class="anniversary-label">together since</span>
    <span class="anniversary-label" data-editable data-key="anniversaryText">June 14, 2023</span>
    <span class="edit-ctrl" style="align-items:center;gap:6px;font-size:12px;color:var(--muted);">
      · change: <input type="date" id="anniversaryDateInput" style="font-size:12px;padding:3px 8px;border:1px solid var(--border);border-radius:6px;background:white;color:var(--walnut);outline:none;font-family:var(--sans);"/>
    </span>
  </div>
  <a href="#gallery" class="heartbeat" aria-label="Scroll down">♡</a>
  <div class="scroll-hint">scroll</div>
</section>

<!-- GALLERY -->
<section id="gallery" class="full-bleed">
  <div class="section fade-in">
    <p class="section-label" data-editable data-key="galLabel">Memories</p>
    <h2 class="section-heading"><span data-editable data-key="galTitle1">Our</span> <em data-editable data-key="galTitle2">favorite</em><br><span data-editable data-key="galTitle3">moments</span></h2>
    <div class="gallery-actions">
      <button class="btn-upload" id="openUploadModal">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
        Add photos
      </button>
      <div class="gallery-filter">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="travel">Travel</button>
        <button class="filter-btn" data-filter="dates">Dates</button>
        <button class="filter-btn" data-filter="everyday">Everyday</button>
        <button class="filter-btn" data-filter="milestones">Milestones</button>
      </div>
    </div>
    <!-- Albums list view -->
    <div class="albums-grid" id="albumsGrid">
      <div class="gallery-empty" id="galleryEmpty">
