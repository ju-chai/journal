function renderTimeline() {
  const list = document.getElementById('timelineList'); list.innerHTML = '';
  D.timeline.forEach(item => {
    if (!item.photos) item.photos = [];
    const div = document.createElement('div'); div.className = 'tl-item'; div.dataset.id = item.id;
    const badge = item.badgeLabel ? '<span class="tl-badge ' + (item.badge==='milestone'?'milestone':'') + '" data-editable data-key="tlBadge_' + item.id + '">' + item.badgeLabel + '</span>' : '';
    div.innerHTML = '<div class="tl-dot ' + (item.future?'future':'') + '"></div>' + badge +
      '<p class="tl-year" data-editable data-key="tlDate_' + item.id + '">' + item.date + '</p>' +
      '<h3 class="tl-title" data-editable data-key="tlTitle_' + item.id + '">' + item.title + '</h3>' +
      '<p class="tl-desc" data-editable="block" data-key="tlDesc_' + item.id + '">' + item.desc + '</p>' +
      '<div class="tl-photos" id="tlPhotos_' + item.id + '"></div>' +
      '<input type="file" class="tl-photo-upload" id="tlUpload_' + item.id + '" accept="image/*" multiple/>' +
      '<button class="tl-remove edit-ctrl" onclick="removeTlItem(' + item.id + ')">Remove milestone</button>';
    list.appendChild(div);
    // Render existing photos
    renderTlPhotos(item);
  });
  applyTexts(); reapplyEditables();
}

function renderTlPhotos(item) {
  const strip = document.getElementById('tlPhotos_' + item.id);
  if (!strip) return;
  strip.innerHTML = '';
  // Existing photos
  (item.photos || []).forEach((photo, idx) => {
    const thumb = document.createElement('div');
    thumb.className = 'tl-photo';
    thumb.innerHTML = '<img src="' + (photo.url || photo.dataUrl) + '" alt="' + (photo.caption||'') + '" loading="lazy"/>';
    thumb.addEventListener('click', () => {
      if (document.body.classList.contains('editing')) {
        if (confirm('Remove this photo from the milestone?')) {
          item.photos.splice(idx, 1);
          renderTlPhotos(item);
          ghSaveData(D);
        }
      } else {
        // Open in lightbox-style
        openTlPhotoViewer(photo.url || photo.dataUrl, photo.caption);
      }
    });
    strip.appendChild(thumb);
  });
  // Add photo button (edit mode only)
  const addBtn = document.createElement('div');
  addBtn.className = 'tl-photo-empty edit-ctrl';
  addBtn.innerHTML = '+';
  addBtn.title = 'Add photo to this milestone';
  addBtn.addEventListener('click', () => {
    const input = document.getElementById('tlUpload_' + item.id);
    if (input) input.click();
  });
  strip.appendChild(addBtn);
  // Wire up file input
  const input = document.getElementById('tlUpload_' + item.id);
  if (input) {
    input.onchange = null;
    input.addEventListener('change', async (e) => {
      const files = Array.from(e.target.files);
      showToast('Uploading photo…', 'saving', 60000);
      for (const file of files) {
        const dataUrl = await new Promise(res => {
          const r = new FileReader(); r.onload = ev => res(ev.target.result); r.readAsDataURL(file);
        });
        const compressed = await new Promise(res => compressImage(dataUrl, 1000, .82, res));
        const filename = 'tl_' + item.id + '_' + Date.now() + '.jpg';
        const photoObj = await ghSavePhoto(filename, compressed, '', '', 'timeline');
        if (!item.photos) item.photos = [];
        item.photos.push(photoObj);
      }
      renderTlPhotos(item);
      await ghSaveData(D);
      showToast('Photo added ✓', 'success', 3000);
      input.value = '';
    });
  }
  // Reapply edit mode if needed
  if (document.body.classList.contains('editing')) {
    strip.querySelectorAll('.edit-ctrl').forEach(el => el.style.display = 'flex');
  }
}

function openTlPhotoViewer(src, caption) {
  // Reuse the lightbox
  document.getElementById('lbImg').src = src;
  document.getElementById('lbCaption').textContent = caption || '';
  document.getElementById('lbMeta').textContent = '';
  document.getElementById('lbCounter').textContent = '';
  document.getElementById('lbDelete').style.display = 'none';
  document.getElementById('lbPrev').style.display = 'none';
  document.getElementById('lbNext').style.display = 'none';
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function collectTimelineEdits() {
  D.timeline.forEach(item => {
    ['tlDate_','tlTitle_','tlDesc_','tlBadge_'].forEach(pfx => {
      const el = document.querySelector('[data-key="' + pfx + item.id + '"]');
      if (!el) return;
      if (pfx==='tlDate_')  item.date       = el.textContent;
      if (pfx==='tlTitle_') item.title      = el.textContent;
      if (pfx==='tlDesc_')  item.desc       = el.textContent;
      if (pfx==='tlBadge_') item.badgeLabel = el.textContent;
    });
    // photos are already updated in-place by renderTlPhotos
  });
}
function removeTlItem(id) {
  if (!confirm('Remove this milestone?')) return;
  D.timeline = D.timeline.filter(i => i.id !== id);
  renderTimeline(); ghSaveData(D);
}
const tlModal = document.getElementById('tlModal');
document.getElementById('addTlBtn').addEventListener('click', () => tlModal.classList.add('open'));
document.getElementById('closeTlModal').addEventListener('click', () => tlModal.classList.remove('open'));
document.getElementById('cancelTl').addEventListener('click', () => tlModal.classList.remove('open'));
tlModal.addEventListener('click', e => { if (e.target === tlModal) tlModal.classList.remove('open'); });
document.getElementById('saveTl').addEventListener('click', async () => {
  const title = document.getElementById('tlTitle').value.trim(); if (!title) return;
  const bk = document.getElementById('tlBadge').value;
  const bm = { milestone:'Milestone', moment:'A moment', growing:'Growing together', beginning:'The beginning' };
  const item = { id:Date.now(), date:document.getElementById('tlDate').value.trim()||'A moment in time', badge:bk, badgeLabel:bm[bk]||'', title, desc:document.getElementById('tlDesc').value.trim(), future:false };
  const fi = D.timeline.findIndex(i => i.future);
  if (fi >= 0) D.timeline.splice(fi, 0, item); else D.timeline.push(item);
  renderTimeline();
  ['tlDate','tlTitle','tlDesc'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('tlBadge').value = '';
  tlModal.classList.remove('open'); reapplyEditables();
  await ghSaveData(D);
});

