let editMode = false;
const editToggle = document.getElementById('editToggle');

function applyTexts() {
  document.querySelectorAll('[data-key]').forEach(el => {
    const val = D.texts[el.dataset.key];
    if (val !== undefined) el.textContent = val;
  });
}
function collectTexts() {
  document.querySelectorAll('[data-key]').forEach(el => { D.texts[el.dataset.key] = el.textContent; });
}
function setEditables(on) {
  document.querySelectorAll('[data-editable]').forEach(el => {
    el.contentEditable = on ? 'true' : 'false';
    if (el.tagName === 'A') el.style.pointerEvents = on ? 'none' : '';
  });
}
function setEditMode(on) {
  editMode = on;
  document.body.classList.toggle('editing', on);
  editToggle.classList.toggle('active', on);
  editToggle.innerHTML = on
    ? '<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg> Done'
    : '<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg> Edit';
  setEditables(on);
  if (!on) {
    collectTexts();
    collectTimelineEdits();
    collectBucketEdits();
    collectNoteEdits();
    applyTexts(); // re-apply to DOM so display matches exactly what was saved
    ghSaveData(D);
  }
}
editToggle.addEventListener('click', () => setEditMode(!editMode));
document.addEventListener('keydown', e => {
  if (editMode && e.key === 'Enter' && e.target.hasAttribute('data-editable')) { e.preventDefault(); e.target.blur(); }
});
function reapplyEditables() { if (editMode) setEditables(true); }

